<Window x:Class="Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FXF3A Tool â€” Authentication"
        Width="400" Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F0F2F5">

    <Window.Resources>
        <ResourceDictionary Source="/Resources/Styles.xaml"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Prompt text -->
        <TextBlock Grid.Row="0"
                   x:Name="PromptText"
                   FontFamily="Calibri" FontSize="12"
                   Foreground="#1E2A3B"
                   TextWrapping="Wrap"/>

        <!-- PasswordBox -->
        <PasswordBox Grid.Row="2"
                     x:Name="PwdBox"
                     FontFamily="Calibri" FontSize="12"
                     Padding="6,4"
                     BorderBrush="#DDE1EB"
                     BorderThickness="1"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="80" Height="30" Margin="0,0,8,0"
                    Background="#1A7A40" Foreground="White"
                    FontFamily="Calibri" FontSize="11" FontWeight="Bold"
                    BorderThickness="0"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button Content="Cancel"
                    Width="80" Height="30"
                    Background="#888888" Foreground="White"
                    FontFamily="Calibri" FontSize="11"
                    BorderThickness="0"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
