                <DataGridTextColumn Header="S6_MIN_AMT"  Width="75"
                    Binding="{Binding S6MinAmt,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S6_MAX_AMT"  Width="75"
                    Binding="{Binding S6MaxAmt,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S6_APP"      Width="50"
                    Binding="{Binding S6App,        UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S6_COND_ID"  Width="80"
                    Binding="{Binding S6CondId,     UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Surcharge/Allowance row 7 -->
                <DataGridTextColumn Header="S7_COND"     Width="70"
                    Binding="{Binding S7Cond,       UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S7_DESC"     Width="120"
                    Binding="{Binding S7Desc,       UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S7_MIN_WGT"  Width="75"
