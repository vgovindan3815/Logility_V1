                <DataGridTextColumn Header="S5_APP"      Width="50"
                    Binding="{Binding S5App,        UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S5_COND_ID"  Width="80"
                    Binding="{Binding S5CondId,     UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Surcharge/Allowance row 6 -->
