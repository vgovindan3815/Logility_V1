                <DataGridTextColumn Header="S9_APP"      Width="50"
                    Binding="{Binding S9App,        UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S9_COND_ID"  Width="80"
                    Binding="{Binding S9CondId,     UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Surcharge/Allowance row 10 -->
