                    Binding="{Binding S10Cond,      UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S10_DESC"    Width="120"
                    Binding="{Binding S10Desc,      UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S10_MIN_WGT" Width="75"
                    Binding="{Binding S10MinWgt,    UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S10_MAX_WGT" Width="75"
                    Binding="{Binding S10MaxWgt,    UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S10_TYPE"    Width="70"
                    Binding="{Binding S10Type,      UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S10_AMT"     Width="75"
