                <DataGridTextColumn Header="S7_MIN_AMT"  Width="75"
                    Binding="{Binding S7MinAmt,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S7_MAX_AMT"  Width="75"
                    Binding="{Binding S7MaxAmt,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S7_APP"      Width="50"
                    Binding="{Binding S7App,        UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S7_COND_ID"  Width="80"
                    Binding="{Binding S7CondId,     UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Surcharge/Allowance row 8 -->
                <DataGridTextColumn Header="S8_COND"     Width="70"
