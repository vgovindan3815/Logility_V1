                <DataGridTextColumn Header="S4_MIN_AMT"  Width="75"
                    Binding="{Binding S4MinAmt,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S4_MAX_AMT"  Width="75"
