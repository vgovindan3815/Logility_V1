                <DataGridTextColumn Header="S4_APP"      Width="50"
                    Binding="{Binding S4App,        UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S4_COND_ID"  Width="80"
                    Binding="{Binding S4CondId,     UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Surcharge/Allowance row 5 -->
                <DataGridTextColumn Header="S5_COND"     Width="70"
                    Binding="{Binding S5Cond,       UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S5_DESC"     Width="120"
                    Binding="{Binding S5Desc,       UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S5_MIN_WGT"  Width="75"
                    Binding="{Binding S5MinWgt,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S5_MAX_WGT"  Width="75"
                    Binding="{Binding S5MaxWgt,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="S5_TYPE"     Width="70"
