<UserControl x:Class="Views.FXF3A_View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FXF3A_Tool.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="#F0F2F5">

    <UserControl.Resources>
        <ResourceDictionary Source="/Resources/Styles.xaml"/>
    </UserControl.Resources>

    <!-- DataContext is set automatically by MainWindow DataTemplate binding -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Screen title + quick load bar -->
            <RowDefinition Height="Auto"/>  <!-- Banner message -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Progress bar -->
            <RowDefinition Height="2*"/>    <!-- Batch DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Results header + toggle -->
            <RowDefinition Height="*"/>     <!-- Results DataGrid -->
        </Grid.RowDefinitions>

        <!-- Row 0: Title + Quick Load ============================ -->
        <Border Grid.Row="0" Background="#0F1C3F" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="FXF3A — Customer Discount Items"
                               Foreground="White" FontFamily="Calibri"
                               FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="CICS Screen 3A  |  Logility Pricing  |  All CRUD operations supported"
                               Foreground="#8899BB" FontFamily="Calibri" FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Quick load bar -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Carrier" Foreground="#8899BB" FontFamily="Calibri"
                               FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="90" Height="24" Margin="0,0,6,0"
                              FontFamily="Calibri" FontSize="11"
                              SelectedValue="{Binding QuickCarrier}"
                              SelectedValuePath="Content">
                        <ComboBoxItem Content="ARFW"/>
                        <ComboBoxItem Content="VIKN"/>
                        <ComboBoxItem Content="FXFM" IsSelected="True"/>
                        <ComboBoxItem Content="FXNL"/>
                        <ComboBoxItem Content="FXFC_INTRACANADA"/>
                        <ComboBoxItem Content="FXFC_CROSSBORDER"/>
                        <ComboBoxItem Content="DFLT"/>
                    </ComboBox>

                    <TextBlock Text="Type" Foreground="#8899BB" FontFamily="Calibri"
                               FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="60" Height="24" Margin="0,0,6,0"
                              FontFamily="Calibri" FontSize="11"
                              SelectedValue="{Binding QuickCustType}"
                              SelectedValuePath="Content">
                        <ComboBoxItem Content="CC" IsSelected="True"/>
                        <ComboBoxItem Content="CN"/>
                        <ComboBoxItem Content="NC"/>
                        <ComboBoxItem Content="NN"/>
                        <ComboBoxItem Content="EN"/>
                        <ComboBoxItem Content="FA"/>
                        <ComboBoxItem Content="SG"/>
                        <ComboBoxItem Content="GR"/>
                        <ComboBoxItem Content="CY"/>
                        <ComboBoxItem Content="DV"/>
                        <ComboBoxItem Content="GE"/>
                    </ComboBox>

                    <TextBlock Text="Account" Foreground="#8899BB" FontFamily="Calibri"
                               FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="110" Height="24" Margin="0,0,6,0"
                             FontFamily="Calibri" FontSize="11"
                             Text="{Binding QuickAccount, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" Padding="4,0"/>

                    <Button Content="Load Items ?"
                            Command="{Binding LoadAccountCommand}"
                            Style="{StaticResource ConnectButtonStyle}"
                            Width="90" Height="24"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Banner message ================================- -->
        <Border Grid.Row="1" Padding="12,5"
                Visibility="{Binding BannerMessage,
                    Converter={StaticResource StringToVisibilityConverter}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#D1FAE5"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding BannerIsError}" Value="True">
                            <Setter Property="Background" Value="#FEE2E2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding BannerMessage}"
                       FontFamily="Calibri" FontSize="11"
                       Foreground="#1E2A3B"/>
        </Border>

        <!-- Row 2: Toolbar ======================================- -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DDE1EB"
                BorderThickness="0,0,0,1" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <Button Content="?  Run Batch"
                        Command="{Binding RunBatchCommand}"
                        Style="{StaticResource RunButtonStyle}"
                        Margin="0,0,8,0"/>
                <Button Content="+  Add Row"
                        Command="{Binding AddRowCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" Width="80"/>
                <Button Content="?  Clear Batch"
                        Command="{Binding ClearBatchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" Width="90"
                        Background="#883333"/>
                <Button Content="Import CSV"
                        Command="{Binding LoadCsvCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0" Width="100"/>
                <Button Content="Select All"
                        Command="{Binding SelectAllCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="4,0,0,0" Width="80"/>
                <Separator Width="1" Background="#DDE1EB" Margin="4,0"/>
                <Button Content="?  Export Results"
                        Command="{Binding ExportResultsCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0" Width="110"/>
            </StackPanel>
        </Border>

        <!-- Row 3: Progress bar ================================== -->
        <Border Grid.Row="3" Background="#EEF0F8" Padding="10,4"
                Visibility="{Binding IsBusy,
                    Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0" Height="8"
                             Minimum="0"
                             Maximum="{Binding ProgressTotal}"
                             Value="{Binding ProgressCurrent}"
                             Foreground="#460073" Background="#DDE1EB"
                             BorderThickness="0"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ProgressText}"
                           FontFamily="Calibri" FontSize="10"
                           Foreground="#555E7A" Margin="10,0,0,0"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Row 4: Batch DataGrid ================================ -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding BatchRows}"
                  Style="{StaticResource BatchDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                  Margin="0">

            <DataGrid.Columns>

                <!-- Row selection checkbox -->
                <DataGridTemplateColumn Header="" Width="30" CanUserSort="False" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Key columns (frozen so they stay visible when scrolling) -->
                <DataGridComboBoxColumn Header="ACTION" Width="90"
                    SelectedValueBinding="{Binding Action, UpdateSourceTrigger=PropertyChanged}"
                    >
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="sys:String"
                                 xmlns:sys="clr-namespace:System;assembly=mscorlib">
                            <sys:String>GET</sys:String>
                            <sys:String>ADD</sys:String>
                            <sys:String>CHANGE</sys:String>
                            <sys:String>CANCEL</sys:String>
                            <sys:String>DELETE</sys:String>
                            <sys:String>RELEASE</sys:String>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>

                <DataGridComboBoxColumn Header="CARRIER" Width="80"
                    SelectedValueBinding="{Binding Carrier}"
                    >
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="sys:String"
                                 xmlns:sys="clr-namespace:System;assembly=mscorlib">
                            <sys:String>ARFW</sys:String>
                            <sys:String>VIKN</sys:String>
                            <sys:String>FXFM</sys:String>
                            <sys:String>FXNL</sys:String>
                            <sys:String>FXFC_INTRACANADA</sys:String>
                            <sys:String>FXFC_CROSSBORDER</sys:String>
                            <sys:String>DFLT</sys:String>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>

                <DataGridComboBoxColumn Header="CUST TYPE" Width="80"
                    SelectedValueBinding="{Binding CustType}"
                    >
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="sys:String"
                                 xmlns:sys="clr-namespace:System;assembly=mscorlib">
                            <sys:String>CC</sys:String>
                            <sys:String>CN</sys:String>
                            <sys:String>NC</sys:String>
                            <sys:String>NN</sys:String>
                            <sys:String>EN</sys:String>
                            <sys:String>FA</sys:String>
                            <sys:String>SG</sys:String>
                            <sys:String>GR</sys:String>
                            <sys:String>CY</sys:String>
                            <sys:String>DV</sys:String>
                            <sys:String>GE</sys:String>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>

                <DataGridTextColumn Header="ACCOUNT"   Width="110" 
                    Binding="{Binding Account,   UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="AUTHORITY" Width="90"
                    Binding="{Binding Authority, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="NUMBER"    Width="80"
                    Binding="{Binding Number,    UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="ITEM"      Width="90"
                    Binding="{Binding Item,      UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridTemplateColumn Header="REL?" Width="50" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding Release, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                                <sys:String>N</sys:String>
                                <sys:String>Y</sys:String>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="CANCEL DATE" Width="90"
                    Binding="{Binding CancelDate, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Discount row 1 -->
                <DataGridTextColumn Header="DISC1"     Width="60"
                    Binding="{Binding Disc1,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="MIN_CHG1"  Width="72"
                    Binding="{Binding MinChg1,   UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="MAX_WGT1"  Width="72"
                    Binding="{Binding MaxWgt1,   UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="FLOOR1"    Width="60"
                    Binding="{Binding FloorMin1, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="EFF_DT1"   Width="76"
                    Binding="{Binding EffDate1,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="CAN_DT1"   Width="76"
                    Binding="{Binding CanDate1,  UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Discount row 2 -->
                <DataGridTextColumn Header="DISC2"     Width="60"
                    Binding="{Binding Disc2,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="MIN_CHG2"  Width="72"
                    Binding="{Binding MinChg2,   UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="MAX_WGT2"  Width="72"
                    Binding="{Binding MaxWgt2,   UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="FLOOR2"    Width="60"
                    Binding="{Binding FloorMin2, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="EFF_DT2"   Width="76"
                    Binding="{Binding EffDate2,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="CAN_DT2"   Width="76"
                    Binding="{Binding CanDate2,  UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Discount row 3 -->
                <DataGridTextColumn Header="DISC3"     Width="60"
                    Binding="{Binding Disc3,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="MIN_CHG3"  Width="72"
                    Binding="{Binding MinChg3,   UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="MAX_WGT3"  Width="72"
                    Binding="{Binding MaxWgt3,   UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="FLOOR3"    Width="60"
                    Binding="{Binding FloorMin3, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="EFF_DT3"   Width="76"
                    Binding="{Binding EffDate3,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="CAN_DT3"   Width="76"
                    Binding="{Binding CanDate3,  UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Item attributes -->
                <DataGridTextColumn Header="CURRENCY"  Width="70"
                    Binding="{Binding Currency,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="FS_AUTH"   Width="75"
                    Binding="{Binding FsAuth,    UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="FS_NUM"    Width="70"
                    Binding="{Binding FsNum,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="FS_ITEM"   Width="70"
                    Binding="{Binding FsItem,    UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTemplateColumn Header="PREPD_IN" Width="65" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <ComboBox SelectedItem="{Binding PrepdIn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                            <sys:String>N</sys:String><sys:String>Y</sys:String>
                        </ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="PREPD_OUT" Width="72" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <ComboBox SelectedItem="{Binding PrepdOut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                            <sys:String>N</sys:String><sys:String>Y</sys:String>
                        </ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="COLL_IN" Width="62" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <ComboBox SelectedItem="{Binding CollIn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                            <sys:String>N</sys:String><sys:String>Y</sys:String>
                        </ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="COLL_OUT" Width="70" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <ComboBox SelectedItem="{Binding CollOut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                            <sys:String>N</sys:String><sys:String>Y</sys:String>
                        </ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="3RD_PTY" Width="60" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <ComboBox SelectedItem="{Binding ThirdParty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                            <sys:String>N</sys:String><sys:String>Y</sys:String>
                        </ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="INTER"     Width="55"
                    Binding="{Binding Inter,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="TYPE_HAUL" Width="100"
                    Binding="{Binding TypeHaul,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="COUNTRY"   Width="70"
                    Binding="{Binding Country,   UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="MATRIX"    Width="65"
                    Binding="{Binding Matrix,    UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GEO_DIR1"  Width="70"
                    Binding="{Binding GeoDir1,   UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GEO_TYPE1" Width="80"
                    Binding="{Binding GeoType1,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GEO_NAME1" Width="120"
                    Binding="{Binding GeoName1,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GEO_ST1"   Width="60"
                    Binding="{Binding GeoSt1,    UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GEO_CTY1"  Width="70"
                    Binding="{Binding GeoCty1,   UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GEO_DIR2"  Width="70"
                    Binding="{Binding GeoDir2,   UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GEO_TYPE2" Width="80"
                    Binding="{Binding GeoType2,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GEO_NAME2" Width="120"
                    Binding="{Binding GeoName2,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RATES_EFF" Width="80"
                    Binding="{Binding RatesEff,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="CLS_ZIP"   Width="70"
                    Binding="{Binding ClsZip,    UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTemplateColumn Header="APPLY_ARB" Width="75" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <ComboBox SelectedItem="{Binding ApplyArbs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                            <sys:String>N</sys:String><sys:String>Y</sys:String>
                        </ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="MIN_WGT"   Width="70"
                    Binding="{Binding MinWgt,    UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="MAX_WGT"   Width="70"
                    Binding="{Binding MaxWgt,    UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTemplateColumn Header="INC_EXM" Width="65" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <ComboBox SelectedItem="{Binding IncExempt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                            <sys:String>N</sys:String><sys:String>Y</sys:String>
                        </ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="FAK" Width="45" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <ComboBox SelectedItem="{Binding Fak, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                            <sys:String>N</sys:String><sys:String>Y</sys:String>
                        </ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- NMFC flags — narrow columns -->
                <DataGridTemplateColumn Header="N50"  Width="38" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N50,   Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N55"  Width="38" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N55,   Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N60"  Width="38" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N60,   Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N65"  Width="38" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N65,   Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N70"  Width="38" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N70,   Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N77"  Width="38" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N77_5, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N85"  Width="38" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N85,   Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N92"  Width="38" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N92_5, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N100" Width="42" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N100,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N110" Width="42" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N110,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N125" Width="42" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N125,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N150" Width="42" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N150,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N175" Width="42" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N175,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N200" Width="42" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N200,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N250" Width="42" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N250,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N300" Width="42" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N300,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N400" Width="42" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N400,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                <DataGridTemplateColumn Header="N500" Width="42" CanUserResize="False" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox SelectedItem="{Binding N500,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center"><sys:String>N</sys:String><sys:String>Y</sys:String></ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>

                <DataGridTextColumn Header="PAY_RULE1" Width="80"
                    Binding="{Binding PayRule1, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="PAY_RULE2" Width="80"
                    Binding="{Binding PayRule2, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- STATUS — always last, wide enough for error messages -->
                <DataGridTemplateColumn Header="STATUS" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusIcon}"
                                       ToolTip="{Binding StatusMessage}"
                                       FontFamily="Calibri" FontSize="11"
                                       VerticalAlignment="Center"
                                       Padding="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 5: Results section header ======================- -->
        <Border Grid.Row="5" Background="#1A2E5A" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="GET Results"
                               Foreground="White" FontFamily="Calibri"
                               FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Results.Count, StringFormat=' ({0} rows)'}"
                               Foreground="#8899BB" FontFamily="Calibri" FontSize="11"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="? Export"
                            Command="{Binding ExportResultsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="70" Height="24" Margin="0,0,6,0"/>
                    <Button Content="? Clear"
                            Command="{Binding ClearResultsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="60" Height="24" Background="#883333"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 6: Results DataGrid ============================- -->
        <DataGrid Grid.Row="6"
                  ItemsSource="{Binding Results}"
                  IsReadOnly="True"
                  Style="{StaticResource BatchDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Account"   Width="110" Binding="{Binding Account}"/>
                <DataGridTextColumn Header="Authority" Width="90"  Binding="{Binding Authority}"/>
                <DataGridTextColumn Header="Number"    Width="80"  Binding="{Binding Number}"/>
                <DataGridTextColumn Header="Item"      Width="90"  Binding="{Binding Item}"/>
                <DataGridTextColumn Header="Disc1"     Width="60"  Binding="{Binding Disc1}"/>
                <DataGridTextColumn Header="EffDate1"  Width="76"  Binding="{Binding EffDate1}"/>
                <DataGridTextColumn Header="CanDate1"  Width="76"  Binding="{Binding CanDate1}"/>
                <DataGridTextColumn Header="Currency"  Width="70"  Binding="{Binding Currency}"/>
                <DataGridTextColumn Header="Inter"     Width="55"  Binding="{Binding Inter}"/>
                <DataGridTextColumn Header="TypeHaul"  Width="100" Binding="{Binding TypeHaul}"/>
                <DataGridTextColumn Header="GeoDir1"   Width="70"  Binding="{Binding GeoDir1}"/>
                <DataGridTextColumn Header="GeoType1"  Width="80"  Binding="{Binding GeoType1}"/>
                <DataGridTextColumn Header="GeoName1"  Width="120" Binding="{Binding GeoName1}"/>
                <DataGridTextColumn Header="LastMaint" Width="90"  Binding="{Binding LastMaintDate}"/>
                <DataGridTextColumn Header="Operator"  Width="80"  Binding="{Binding OperatorId}"/>
                <DataGridTextColumn Header="Revision"  Width="70"  Binding="{Binding Revision}"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
