<UserControl x:Class="Views.FXF3N_View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FXF3A_Tool.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="#F0F2F5">

    <UserControl.Resources>
        <ResourceDictionary Source="/Resources/Styles.xaml"/>
    </UserControl.Resources>

    <!-- DataContext is set automatically by MainWindow DataTemplate binding -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Screen title -->
            <RowDefinition Height="Auto"/>  <!-- Banner message -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Progress bar -->
            <RowDefinition Height="2*"/>    <!-- Batch DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Results header -->
            <RowDefinition Height="*"/>     <!-- Results DataGrid -->
        </Grid.RowDefinitions>

        <!-- Row 0: Title ========================================- -->
        <Border Grid.Row="0" Background="#0F1C3F" Padding="12,8">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="FXF3N — Unit Rates"
                           Foreground="White" FontFamily="Calibri"
                           FontSize="14" FontWeight="Bold"/>
                <TextBlock Text="DSNM1UR-3N  |  GET · ADD · CHANGE · CANCEL · DELETE"
                           Foreground="#8899BB" FontFamily="Calibri" FontSize="10" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Row 1: Banner message ================================- -->
        <Border Grid.Row="1" Padding="12,5"
                Visibility="{Binding BannerMessage,
                    Converter={StaticResource StringToVisibilityConverter}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#D1FAE5"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding BannerIsError}" Value="True">
                            <Setter Property="Background" Value="#FEE2E2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding BannerMessage}"
                       FontFamily="Calibri" FontSize="11"
                       Foreground="#1E2A3B"/>
        </Border>

        <!-- Row 2: Toolbar ======================================- -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DDE1EB"
                BorderThickness="0,0,0,1" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <Button Content="?  Run Batch"
                        Command="{Binding RunBatchCommand}"
                        Style="{StaticResource RunButtonStyle}"
                        Margin="0,0,8,0"/>
                <Button Content="+  Add Row"
                        Command="{Binding AddRowCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" Width="80"/>
                <Button Content="?  Clear Batch"
                        Command="{Binding ClearBatchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" Width="90"
                        Background="#883333"/>
                <Button Content="Import CSV"
                        Command="{Binding LoadCsvCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0" Width="100"/>
                <Button Content="Select All"
                        Command="{Binding SelectAllCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="4,0,0,0" Width="80"/>
                <Separator Width="1" Background="#DDE1EB" Margin="4,0"/>
                <Button Content="?  Export Results"
                        Command="{Binding ExportResultsCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0" Width="110"/>
            </StackPanel>
        </Border>

        <!-- Row 3: Progress bar ================================== -->
        <Border Grid.Row="3" Background="#EEF0F8" Padding="10,4"
                Visibility="{Binding IsBusy,
                    Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0" Height="8"
                             Minimum="0"
                             Maximum="{Binding ProgressTotal}"
                             Value="{Binding ProgressCurrent}"
                             Foreground="#460073" Background="#DDE1EB"
                             BorderThickness="0"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ProgressText}"
                           FontFamily="Calibri" FontSize="10"
                           Foreground="#555E7A" Margin="10,0,0,0"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Row 4: Batch DataGrid ================================ -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding BatchRows}"
                  CanUserAddRows="False"
                  Style="{StaticResource BatchDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  Margin="0">

            <DataGrid.Columns>

                <!-- Row selection checkbox -->
                <DataGridTemplateColumn Header="" Width="30" CanUserSort="False" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Frozen key columns -->
                <DataGridComboBoxColumn Header="ACTION" Width="90"
                    SelectedValueBinding="{Binding Action, UpdateSourceTrigger=PropertyChanged}"
                    >
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="sys:String">
                            <sys:String>GET</sys:String>
                            <sys:String>ADD</sys:String>
                            <sys:String>CHANGE</sys:String>
                            <sys:String>CANCEL</sys:String>
                            <sys:String>DELETE</sys:String>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>

                <DataGridComboBoxColumn Header="CARRIER" Width="80"
                    SelectedValueBinding="{Binding Carrier, UpdateSourceTrigger=PropertyChanged}"
                    >
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="sys:String">
                            <sys:String>ARFW</sys:String>
                            <sys:String>VIKN</sys:String>
                            <sys:String>FXFM</sys:String>
                            <sys:String>FXNL</sys:String>
                            <sys:String>DFLT</sys:String>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>

                <DataGridComboBoxColumn Header="CUST_TYPE" Width="85"
                    SelectedValueBinding="{Binding CustType, UpdateSourceTrigger=PropertyChanged}"
                    >
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="sys:String">
                            <sys:String>CC</sys:String>
                            <sys:String>CN</sys:String>
                            <sys:String>NC</sys:String>
                            <sys:String>NN</sys:String>
                            <sys:String>EN</sys:String>
                            <sys:String>FA</sys:String>
                            <sys:String>SG</sys:String>
                            <sys:String>GR</sys:String>
                            <sys:String>CY</sys:String>
                            <sys:String>DV</sys:String>
                            <sys:String>GE</sys:String>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>

                <DataGridTextColumn Header="ACCOUNT" Width="110" 
                    Binding="{Binding Account, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Standard account key fields -->
                <DataGridTextColumn Header="AUTHORITY" Width="90"
                    Binding="{Binding Authority, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="NUMBER" Width="80"
                    Binding="{Binding Number, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="ITEM" Width="80"
                    Binding="{Binding Item, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="PART" Width="70"
                    Binding="{Binding Part, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridTextColumn Header="CANCEL_DATE" Width="95"
                    Binding="{Binding CancelDate, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="CONDITION" Width="85"
                    Binding="{Binding Condition, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridComboBoxColumn Header="PREPD_COLL" Width="90"
                    SelectedValueBinding="{Binding PrepdColl, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="sys:String">
                            <sys:String>NA</sys:String>
                            <sys:String>C</sys:String>
                            <sys:String>P</sys:String>
                            <sys:String>T</sys:String>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>

                <DataGridTextColumn Header="EFF_DATE" Width="80"
                    Binding="{Binding EffDate, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="CAN_DATE" Width="80"
                    Binding="{Binding CanDate, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridComboBoxColumn Header="ALTERNATION" Width="95"
                    SelectedValueBinding="{Binding Alternation, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="sys:String">
                            <sys:String>NA</sys:String>
                            <sys:String>K</sys:String>
                            <sys:String>L</sys:String>
                            <sys:String>N</sys:String>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>

                <DataGridComboBoxColumn Header="CLASS_RATES" Width="95"
                    SelectedValueBinding="{Binding ClassRates, UpdateSourceTrigger=PropertyChanged}">
                    <DataGridComboBoxColumn.ItemsSource>
                        <x:Array Type="sys:String">
                            <sys:String>NA</sys:String>
                            <sys:String>B</sys:String>
                            <sys:String>C</sys:String>
                            <sys:String>D</sys:String>
                            <sys:String>N</sys:String>
                            <sys:String>S</sys:String>
                            <sys:String>X</sys:String>
                        </x:Array>
                    </DataGridComboBoxColumn.ItemsSource>
                </DataGridComboBoxColumn>

                <DataGridTextColumn Header="CLS_TRF_AUTH" Width="100"
                    Binding="{Binding ClsTrfAuth, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="CLS_TRF_NUM" Width="95"
                    Binding="{Binding ClsTrfNum, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="CLS_TRF_SEC" Width="95"
                    Binding="{Binding ClsTrfSec, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RATE_EFF_DATE" Width="105"
                    Binding="{Binding RateEffDate, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="HU_TYPE" Width="80"
                    Binding="{Binding HuType, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="MILEAGE_AUTH" Width="100"
                    Binding="{Binding MileageAuth, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="MILEAGE_NUM" Width="95"
                    Binding="{Binding MileageNum, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="MILEAGE_RANGE_LOW" Width="130"
                    Binding="{Binding MileageRangeLow, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="MILEAGE_RANGE_HIGH" Width="135"
                    Binding="{Binding MileageRangeHigh, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="COMMENTS" Width="180"
                    Binding="{Binding Comments, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Rate row 1 -->
                <DataGridTextColumn Header="RT1_MIN_H" Width="85"
                    Binding="{Binding Rt1MinH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT1_MAX_H" Width="85"
                    Binding="{Binding Rt1MaxH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT1_AVG_MIN" Width="90"
                    Binding="{Binding Rt1AvgMin, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT1_AVG_MAX" Width="90"
                    Binding="{Binding Rt1AvgMax, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT1_RATE_TYPE" Width="100"
                    Binding="{Binding Rt1RateType, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT1_AMT" Width="75"
                    Binding="{Binding Rt1Amt, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Rate row 2 -->
                <DataGridTextColumn Header="RT2_MIN_H" Width="85"
                    Binding="{Binding Rt2MinH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT2_MAX_H" Width="85"
                    Binding="{Binding Rt2MaxH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT2_AVG_MIN" Width="90"
                    Binding="{Binding Rt2AvgMin, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT2_AVG_MAX" Width="90"
                    Binding="{Binding Rt2AvgMax, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT2_RATE_TYPE" Width="100"
                    Binding="{Binding Rt2RateType, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT2_AMT" Width="75"
                    Binding="{Binding Rt2Amt, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Rate row 3 -->
                <DataGridTextColumn Header="RT3_MIN_H" Width="85"
                    Binding="{Binding Rt3MinH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT3_MAX_H" Width="85"
                    Binding="{Binding Rt3MaxH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT3_AVG_MIN" Width="90"
                    Binding="{Binding Rt3AvgMin, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT3_AVG_MAX" Width="90"
                    Binding="{Binding Rt3AvgMax, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT3_RATE_TYPE" Width="100"
                    Binding="{Binding Rt3RateType, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT3_AMT" Width="75"
                    Binding="{Binding Rt3Amt, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Rate row 4 -->
                <DataGridTextColumn Header="RT4_MIN_H" Width="85"
                    Binding="{Binding Rt4MinH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT4_MAX_H" Width="85"
                    Binding="{Binding Rt4MaxH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT4_AVG_MIN" Width="90"
                    Binding="{Binding Rt4AvgMin, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT4_AVG_MAX" Width="90"
                    Binding="{Binding Rt4AvgMax, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT4_RATE_TYPE" Width="100"
                    Binding="{Binding Rt4RateType, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT4_AMT" Width="75"
                    Binding="{Binding Rt4Amt, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Rate row 5 -->
                <DataGridTextColumn Header="RT5_MIN_H" Width="85"
                    Binding="{Binding Rt5MinH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT5_MAX_H" Width="85"
                    Binding="{Binding Rt5MaxH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT5_AVG_MIN" Width="90"
                    Binding="{Binding Rt5AvgMin, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT5_AVG_MAX" Width="90"
                    Binding="{Binding Rt5AvgMax, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT5_RATE_TYPE" Width="100"
                    Binding="{Binding Rt5RateType, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT5_AMT" Width="75"
                    Binding="{Binding Rt5Amt, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Rate row 6 -->
                <DataGridTextColumn Header="RT6_MIN_H" Width="85"
                    Binding="{Binding Rt6MinH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT6_MAX_H" Width="85"
                    Binding="{Binding Rt6MaxH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT6_AVG_MIN" Width="90"
                    Binding="{Binding Rt6AvgMin, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT6_AVG_MAX" Width="90"
                    Binding="{Binding Rt6AvgMax, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT6_RATE_TYPE" Width="100"
                    Binding="{Binding Rt6RateType, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT6_AMT" Width="75"
                    Binding="{Binding Rt6Amt, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Rate row 7 -->
                <DataGridTextColumn Header="RT7_MIN_H" Width="85"
                    Binding="{Binding Rt7MinH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT7_MAX_H" Width="85"
                    Binding="{Binding Rt7MaxH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT7_AVG_MIN" Width="90"
                    Binding="{Binding Rt7AvgMin, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT7_AVG_MAX" Width="90"
                    Binding="{Binding Rt7AvgMax, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT7_RATE_TYPE" Width="100"
                    Binding="{Binding Rt7RateType, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT7_AMT" Width="75"
                    Binding="{Binding Rt7Amt, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Rate row 8 -->
                <DataGridTextColumn Header="RT8_MIN_H" Width="85"
                    Binding="{Binding Rt8MinH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT8_MAX_H" Width="85"
                    Binding="{Binding Rt8MaxH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT8_AVG_MIN" Width="90"
                    Binding="{Binding Rt8AvgMin, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT8_AVG_MAX" Width="90"
                    Binding="{Binding Rt8AvgMax, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT8_RATE_TYPE" Width="100"
                    Binding="{Binding Rt8RateType, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT8_AMT" Width="75"
                    Binding="{Binding Rt8Amt, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Rate row 9 -->
                <DataGridTextColumn Header="RT9_MIN_H" Width="85"
                    Binding="{Binding Rt9MinH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT9_MAX_H" Width="85"
                    Binding="{Binding Rt9MaxH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT9_AVG_MIN" Width="90"
                    Binding="{Binding Rt9AvgMin, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT9_AVG_MAX" Width="90"
                    Binding="{Binding Rt9AvgMax, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT9_RATE_TYPE" Width="100"
                    Binding="{Binding Rt9RateType, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT9_AMT" Width="75"
                    Binding="{Binding Rt9Amt, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Rate row 10 -->
                <DataGridTextColumn Header="RT10_MIN_H" Width="90"
                    Binding="{Binding Rt10MinH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT10_MAX_H" Width="90"
                    Binding="{Binding Rt10MaxH, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT10_AVG_MIN" Width="95"
                    Binding="{Binding Rt10AvgMin, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT10_AVG_MAX" Width="95"
                    Binding="{Binding Rt10AvgMax, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT10_RATE_TYPE" Width="105"
                    Binding="{Binding Rt10RateType, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="RT10_AMT" Width="80"
                    Binding="{Binding Rt10Amt, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- STATUS — always last -->
                <DataGridTemplateColumn Header="STATUS" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusIcon}"
                                       ToolTip="{Binding StatusMessage}"
                                       FontFamily="Calibri" FontSize="11"
                                       VerticalAlignment="Center"
                                       Padding="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="STATUS_MESSAGE" Width="200"
                    IsReadOnly="True"
                    Binding="{Binding StatusMessage}"/>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 5: Results section header ======================- -->
        <Border Grid.Row="5" Background="#1A2E5A" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="GET Results"
                               Foreground="White" FontFamily="Calibri"
                               FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Results.Count, StringFormat=' ({0} rows)'}"
                               Foreground="#8899BB" FontFamily="Calibri" FontSize="11"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="? Export"
                            Command="{Binding ExportResultsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="70" Height="24" Margin="0,0,6,0"/>
                    <Button Content="? Clear"
                            Command="{Binding ClearResultsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="60" Height="24" Background="#883333"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 6: Results DataGrid ============================- -->
        <DataGrid Grid.Row="6"
                  ItemsSource="{Binding Results}"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Style="{StaticResource BatchDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Carrier"      Width="80"  Binding="{Binding Carrier}"/>
                <DataGridTextColumn Header="CustType"     Width="80"  Binding="{Binding CustType}"/>
                <DataGridTextColumn Header="Account"      Width="110" Binding="{Binding Account}"/>
                <DataGridTextColumn Header="Authority"    Width="90"  Binding="{Binding Authority}"/>
                <DataGridTextColumn Header="Number"       Width="80"  Binding="{Binding Number}"/>
                <DataGridTextColumn Header="Item"         Width="80"  Binding="{Binding Item}"/>
                <DataGridTextColumn Header="Part"         Width="70"  Binding="{Binding Part}"/>
                <DataGridTextColumn Header="Condition"    Width="85"  Binding="{Binding Condition}"/>
                <DataGridTextColumn Header="EffDate"      Width="80"  Binding="{Binding EffDate}"/>
                <DataGridTextColumn Header="HuType"       Width="80"  Binding="{Binding HuType}"/>
                <DataGridTextColumn Header="Rt1MinH"      Width="80"  Binding="{Binding Rt1MinH}"/>
                <DataGridTextColumn Header="Rt1MaxH"      Width="80"  Binding="{Binding Rt1MaxH}"/>
                <DataGridTextColumn Header="Rt1RateType"  Width="95"  Binding="{Binding Rt1RateType}"/>
                <DataGridTextColumn Header="Rt1Amt"       Width="75"  Binding="{Binding Rt1Amt}"/>
                <DataGridTextColumn Header="Status"       Width="120" Binding="{Binding Status}"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
