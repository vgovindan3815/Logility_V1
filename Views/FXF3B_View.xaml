<UserControl x:Class="Views.FXF3B_View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Logility_Freight.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="#F0F2F5">

    <UserControl.Resources>
        <ResourceDictionary Source="/Resources/Styles.xaml"/>
    </UserControl.Resources>

    <!-- DataContext is set automatically by MainWindow DataTemplate binding -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Screen title -->
            <RowDefinition Height="Auto"/>  <!-- Banner message -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Progress bar -->
            <RowDefinition Height="2*"/>    <!-- Batch DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Results header -->
            <RowDefinition Height="*"/>     <!-- Results DataGrid -->
        </Grid.RowDefinitions>

        <!-- Row 0: Title (no quick-load bar for FXF3B) ==========- -->
        <Border Grid.Row="0" Background="#0F1C3F" Padding="12,8">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="FXF3B — Discounts by State/Terminal"
                           Foreground="White" FontFamily="Calibri"
                           FontSize="14" FontWeight="Bold"/>
                <TextBlock Text="DSNM1ST-3B  |  GET · ADD · CHANGE · DELETE"
                           Foreground="#8899BB" FontFamily="Calibri" FontSize="10" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Row 1: Banner message ================================- -->
        <Border Grid.Row="1" Padding="12,5"
                Visibility="{Binding BannerMessage,
                    Converter={StaticResource StringToVisibilityConverter}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#D1FAE5"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding BannerIsError}" Value="True">
                            <Setter Property="Background" Value="#FEE2E2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding BannerMessage}"
                       FontFamily="Calibri" FontSize="11"
                       Foreground="#1E2A3B"/>
        </Border>

        <!-- Row 2: Toolbar ======================================- -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DDE1EB"
                BorderThickness="0,0,0,1" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <Button Content="?  Run Batch"
                        Command="{Binding RunBatchCommand}"
                        Click="RunBatch_Click"
                        Style="{StaticResource RunButtonStyle}"
                        Margin="0,0,8,0"/>
                <Button Content="+  Add Row"
                        Command="{Binding AddRowCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" Width="80"/>
                <Button Content="?  Clear Batch"
                        Command="{Binding ClearBatchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" Width="90"
                        Background="#883333"/>
                <Button Content="Import CSV"
                        Command="{Binding LoadCsvCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0" Width="100"/>
                <Button Content="Select All"
                        Command="{Binding SelectAllCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="4,0,0,0" Width="80"/>
                <Separator Width="1" Background="#DDE1EB" Margin="4,0"/>
                <Button Content="?  Export Results"
                        Command="{Binding ExportResultsCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0" Width="110"/>
            </StackPanel>
        </Border>

        <!-- Row 3: Progress bar ================================== -->
        <Border Grid.Row="3" Background="#EEF0F8" Padding="10,4"
                Visibility="{Binding IsBusy,
                    Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0" Height="8"
                             Minimum="0"
                             Maximum="{Binding ProgressTotal}"
                             Value="{Binding ProgressCurrent}"
                             Foreground="#460073" Background="#DDE1EB"
                             BorderThickness="0"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ProgressText}"
                           FontFamily="Calibri" FontSize="10"
                           Foreground="#555E7A" Margin="10,0,0,0"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Row 4: Batch DataGrid ================================ -->
        <DataGrid Grid.Row="4"
                  x:Name="BatchDataGrid"
                  ItemsSource="{Binding BatchRows}"
                  Style="{StaticResource BatchDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                  Margin="0">

            <DataGrid.Columns>

                <!-- Row selection checkbox -->
                <DataGridTemplateColumn Header="" Width="30" CanUserSort="False" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Frozen key columns -->
                <DataGridTemplateColumn Header="ACTION" Width="90" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Action}" FontFamily="Calibri" FontSize="11"
                                       VerticalAlignment="Center" Padding="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding Action, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      BorderThickness="0" Padding="2,0">
                                <sys:String>GET</sys:String>
                                <sys:String>ADD</sys:String>
                                <sys:String>CHANGE</sys:String>
                                <sys:String>DELETE</sys:String>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="CARRIER" Width="80" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Carrier}" FontFamily="Calibri" FontSize="11"
                                       VerticalAlignment="Center" Padding="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding Carrier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      BorderThickness="0" Padding="2,0">
                                <sys:String>ARFW</sys:String>
                                <sys:String>VIKN</sys:String>
                                <sys:String>FXFM</sys:String>
                                <sys:String>FXNL</sys:String>
                                <sys:String>FXFC_INTRACANADA</sys:String>
                                <sys:String>FXFC_CROSSBORDER</sys:String>
                                <sys:String>DFLT</sys:String>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="CUST TYPE" Width="80" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CustType}" FontFamily="Calibri" FontSize="11"
                                       VerticalAlignment="Center" Padding="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding CustType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      BorderThickness="0" Padding="2,0">
                                <sys:String>CC</sys:String>
                                <sys:String>CN</sys:String>
                                <sys:String>NC</sys:String>
                                <sys:String>NN</sys:String>
                                <sys:String>EN</sys:String>
                                <sys:String>FA</sys:String>
                                <sys:String>SG</sys:String>
                                <sys:String>GR</sys:String>
                                <sys:String>CY</sys:String>
                                <sys:String>DV</sys:String>
                                <sys:String>GE</sys:String>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="ACCOUNT"   Width="110" 
                    Binding="{Binding Account,    UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Screen-specific key columns -->
                <DataGridTextColumn Header="AUTHORITY" Width="90"
                    Binding="{Binding Authority,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="NUMBER"    Width="80"
                    Binding="{Binding Number,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="ITEM"      Width="90"
                    Binding="{Binding Item,       UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="PART"      Width="70"
                    Binding="{Binding Part,       UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Flags (no CANCEL_DATE for 3B) -->
                <DataGridTemplateColumn Header="REL?" Width="50" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding Release, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                                <sys:String>N</sys:String>
                                <sys:String>Y</sys:String>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- GT1 geography block -->
                <DataGridTextColumn Header="GT1_INC_EXC" Width="90"
                    Binding="{Binding GT1IncExc,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT1_DIR"     Width="70"
                    Binding="{Binding GT1Dir,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT1_TYPE"    Width="70"
                    Binding="{Binding GT1Type,    UpdateSourceTrigger=PropertyChanged}"/>

                <!-- GT1 restriction rows 1–5 -->
                <DataGridTextColumn Header="GT1R1_NAME"  Width="90"
                    Binding="{Binding GT1R1Name,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT1R1_CTY"   Width="70"
                    Binding="{Binding GT1R1Country, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridTextColumn Header="GT1R2_NAME"  Width="90"
                    Binding="{Binding GT1R2Name,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT1R2_CTY"   Width="70"
                    Binding="{Binding GT1R2Country, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridTextColumn Header="GT1R3_NAME"  Width="90"
                    Binding="{Binding GT1R3Name,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT1R3_CTY"   Width="70"
                    Binding="{Binding GT1R3Country, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridTextColumn Header="GT1R4_NAME"  Width="90"
                    Binding="{Binding GT1R4Name,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT1R4_CTY"   Width="70"
                    Binding="{Binding GT1R4Country, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridTextColumn Header="GT1R5_NAME"  Width="90"
                    Binding="{Binding GT1R5Name,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT1R5_CTY"   Width="70"
                    Binding="{Binding GT1R5Country, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- GT2 geography block -->
                <DataGridTextColumn Header="GT2_INC_EXC" Width="90"
                    Binding="{Binding GT2IncExc,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT2_DIR"     Width="70"
                    Binding="{Binding GT2Dir,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT2_TYPE"    Width="70"
                    Binding="{Binding GT2Type,    UpdateSourceTrigger=PropertyChanged}"/>

                <!-- GT2 restriction rows 1–5 -->
                <DataGridTextColumn Header="GT2R1_NAME"  Width="90"
                    Binding="{Binding GT2R1Name,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT2R1_CTY"   Width="70"
                    Binding="{Binding GT2R1Country, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridTextColumn Header="GT2R2_NAME"  Width="90"
                    Binding="{Binding GT2R2Name,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT2R2_CTY"   Width="70"
                    Binding="{Binding GT2R2Country, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridTextColumn Header="GT2R3_NAME"  Width="90"
                    Binding="{Binding GT2R3Name,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT2R3_CTY"   Width="70"
                    Binding="{Binding GT2R3Country, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridTextColumn Header="GT2R4_NAME"  Width="90"
                    Binding="{Binding GT2R4Name,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT2R4_CTY"   Width="70"
                    Binding="{Binding GT2R4Country, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridTextColumn Header="GT2R5_NAME"  Width="90"
                    Binding="{Binding GT2R5Name,  UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GT2R5_CTY"   Width="70"
                    Binding="{Binding GT2R5Country, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Floor-scale auth reference -->
                <DataGridTextColumn Header="FS_AUTH"     Width="75"
                    Binding="{Binding FsAuth,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="FS_NUM"      Width="70"
                    Binding="{Binding FsNum,      UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="FS_ITEM"     Width="70"
                    Binding="{Binding FsItem,     UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Prepaid / collect flags -->
                <DataGridTemplateColumn Header="PREPD_IN" Width="65" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <ComboBox SelectedItem="{Binding PrepdIn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                            <sys:String>N</sys:String><sys:String>Y</sys:String>
                        </ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="PREPD_OUT" Width="72" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <ComboBox SelectedItem="{Binding PrepdOut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                            <sys:String>N</sys:String><sys:String>Y</sys:String>
                        </ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="COLL_IN" Width="62" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <ComboBox SelectedItem="{Binding CollIn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                            <sys:String>N</sys:String><sys:String>Y</sys:String>
                        </ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="COLL_OUT" Width="70" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <ComboBox SelectedItem="{Binding CollOut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Padding="2,0" HorizontalContentAlignment="Center">
                            <sys:String>N</sys:String><sys:String>Y</sys:String>
                        </ComboBox></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Rate / geography qualifiers -->
                <DataGridTextColumn Header="RATE_EFF"    Width="80"
                    Binding="{Binding RateEff,    UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="CLS_ZIP"     Width="70"
                    Binding="{Binding ClsZip,     UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="GEN_GEO_A"   Width="80"
                    Binding="{Binding GenGeoA,    UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Audit fields -->
                <DataGridTextColumn Header="LAST_MAINT"  Width="90"
                    Binding="{Binding LastMaintDate, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="OPERATOR"    Width="80"
                    Binding="{Binding OperatorId, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="REVISION"    Width="70"
                    Binding="{Binding Revision,   UpdateSourceTrigger=PropertyChanged}"/>

                <!-- STATUS — always last -->
                <DataGridTemplateColumn Header="STATUS" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusIcon}"
                                       ToolTip="{Binding StatusMessage}"
                                       FontFamily="Calibri" FontSize="11"
                                       VerticalAlignment="Center"
                                       Padding="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 5: Results section header ======================- -->
        <Border Grid.Row="5" Background="#1A2E5A" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="GET Results"
                               Foreground="White" FontFamily="Calibri"
                               FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Results.Count, StringFormat=' ({0} rows)'}"
                               Foreground="#8899BB" FontFamily="Calibri" FontSize="11"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="? Export"
                            Command="{Binding ExportResultsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="70" Height="24" Margin="0,0,6,0"/>
                    <Button Content="? Clear"
                            Command="{Binding ClearResultsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="60" Height="24" Background="#883333"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 6: Results DataGrid ============================- -->
        <DataGrid Grid.Row="6"
                  ItemsSource="{Binding Results}"
                  IsReadOnly="True"
                  Style="{StaticResource BatchDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Account"       Width="110" Binding="{Binding Account}"/>
                <DataGridTextColumn Header="Authority"     Width="90"  Binding="{Binding Authority}"/>
                <DataGridTextColumn Header="Number"        Width="80"  Binding="{Binding Number}"/>
                <DataGridTextColumn Header="Item"          Width="90"  Binding="{Binding Item}"/>
                <DataGridTextColumn Header="Part"          Width="70"  Binding="{Binding Part}"/>
                <DataGridTextColumn Header="GT1IncExc"     Width="90"  Binding="{Binding GT1IncExc}"/>
                <DataGridTextColumn Header="GT1Dir"        Width="70"  Binding="{Binding GT1Dir}"/>
                <DataGridTextColumn Header="GT1Type"       Width="70"  Binding="{Binding GT1Type}"/>
                <DataGridTextColumn Header="GT1R1Name"     Width="90"  Binding="{Binding GT1R1Name}"/>
                <DataGridTextColumn Header="GT2IncExc"     Width="90"  Binding="{Binding GT2IncExc}"/>
                <DataGridTextColumn Header="GT2Dir"        Width="70"  Binding="{Binding GT2Dir}"/>
                <DataGridTextColumn Header="GT2Type"       Width="70"  Binding="{Binding GT2Type}"/>
                <DataGridTextColumn Header="GT2R1Name"     Width="90"  Binding="{Binding GT2R1Name}"/>
                <DataGridTextColumn Header="RateEff"       Width="80"  Binding="{Binding RateEff}"/>
                <DataGridTextColumn Header="ClsZip"        Width="70"  Binding="{Binding ClsZip}"/>
                <DataGridTextColumn Header="LastMaintDate" Width="90"  Binding="{Binding LastMaintDate}"/>
                <DataGridTextColumn Header="OperatorId"    Width="80"  Binding="{Binding OperatorId}"/>
                <DataGridTextColumn Header="Status"        Width="120" Binding="{Binding Status}"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
