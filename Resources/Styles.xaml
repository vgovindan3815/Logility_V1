<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ── Colour palette ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="NavyBrush"       Color="#0F1C3F"/>
    <SolidColorBrush x:Key="PurpleBrush"     Color="#460073"/>
    <SolidColorBrush x:Key="AccentBrush"     Color="#A100FF"/>
    <SolidColorBrush x:Key="TealBrush"       Color="#00B0B9"/>
    <SolidColorBrush x:Key="SuccessBrush"    Color="#065F46"/>
    <SolidColorBrush x:Key="ErrorBrush"      Color="#7F1D1D"/>
    <SolidColorBrush x:Key="WarningBrush"    Color="#92400E"/>
    <SolidColorBrush x:Key="ConnectBrush"    Color="#1A7A40"/>
    <SolidColorBrush x:Key="DisconnectBrush" Color="#AA2222"/>
    <SolidColorBrush x:Key="LightGreyBrush"  Color="#F0F2F5"/>
    <SolidColorBrush x:Key="MedGreyBrush"    Color="#DDE1EB"/>
    <SolidColorBrush x:Key="DarkTextBrush"   Color="#1E2A3B"/>
    <SolidColorBrush x:Key="GridHeaderBrush" Color="#1A2E5A"/>
    <SolidColorBrush x:Key="NavRailBrush"    Color="#1A2040"/>

    <!-- ── Value converters ─────────────────────────────────────── -->
    <!-- Defined in Converters.vb, referenced here as static resources -->
    <!-- Add the converters namespace in App.xaml merged dict instead  -->

    <!-- ── Base font ────────────────────────────────────────────── -->
    <sys:Double x:Key="BaseFontSize">11</sys:Double>
    <FontFamily x:Key="BaseFont">Calibri</FontFamily>

    <!-- ── Connection bar TextBox ───────────────────────────────── -->
    <Style x:Key="ConnBarTextBox" TargetType="TextBox">
        <Setter Property="FontFamily"        Value="Calibri"/>
        <Setter Property="FontSize"          Value="11"/>
        <Setter Property="Foreground"        Value="White"/>
        <Setter Property="Background"        Value="#1E2A4A"/>
        <Setter Property="BorderBrush"       Value="#2A3A60"/>
        <Setter Property="BorderThickness"   Value="1"/>
        <Setter Property="Padding"           Value="4,3"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Height"            Value="26"/>
        <Setter Property="Margin"            Value="0,0,6,0"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="#A100FF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── CONNECT button ───────────────────────────────────────── -->
    <Style x:Key="ConnectButtonStyle" TargetType="Button">
        <Setter Property="FontFamily"      Value="Calibri"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="FontWeight"      Value="Bold"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="Background"      Value="#1A7A40"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height"          Value="26"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="3" Padding="8,0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#22A050"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#555555"/>
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── DISCONNECT button ────────────────────────────────────── -->
    <Style x:Key="DisconnectButtonStyle" TargetType="Button"
           BasedOn="{StaticResource ConnectButtonStyle}">
        <Setter Property="Background" Value="#AA2222"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#CC3333"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Run Batch button ─────────────────────────────────────── -->
    <Style x:Key="RunButtonStyle" TargetType="Button"
           BasedOn="{StaticResource ConnectButtonStyle}">
        <Setter Property="Background" Value="#1A7A40"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Height"     Value="30"/>
        <Setter Property="Padding"    Value="14,0"/>
    </Style>

    <!-- ── Secondary action button ──────────────────────────────── -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button"
           BasedOn="{StaticResource ConnectButtonStyle}">
        <Setter Property="Background" Value="#2A3A60"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Height"     Value="28"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#3A4A80"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#555555"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Nav rail item button ──────────────────────────────────── -->
    <Style x:Key="NavItemStyle" TargetType="Button">
        <Setter Property="FontFamily"      Value="Calibri"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Foreground"      Value="#9AA3C0"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height"          Value="36"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding"         Value="16,0,8,0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="NavBorder"
                            Background="{TemplateBinding Background}"
                            BorderThickness="3,0,0,0"
                            BorderBrush="Transparent">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Active state (Tag=True passed from binding) -->
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}"
                                     Value="True">
                            <Setter TargetName="NavBorder" Property="Background"   Value="#2A1050"/>
                            <Setter TargetName="NavBorder" Property="BorderBrush"  Value="#A100FF"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="NavBorder" Property="Background" Value="#222A50"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#445060"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── DataGrid shared style ─────────────────────────────────── -->
    <Style x:Key="BatchDataGridStyle" TargetType="DataGrid">
        <Setter Property="FontFamily"             Value="Calibri"/>
        <Setter Property="FontSize"               Value="11"/>
        <Setter Property="Background"             Value="White"/>
        <Setter Property="RowBackground"          Value="White"/>
        <Setter Property="AlternatingRowBackground" Value="#F4F6FB"/>
        <Setter Property="BorderThickness"        Value="0"/>
        <Setter Property="GridLinesVisibility"    Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#DDE1EB"/>
        <Setter Property="RowHeight"              Value="26"/>
        <Setter Property="CanUserAddRows"         Value="False"/>
        <Setter Property="CanUserDeleteRows"      Value="False"/>
        <Setter Property="AutoGenerateColumns"    Value="False"/>
        <Setter Property="SelectionMode"          Value="Extended"/>
        <Setter Property="ColumnHeaderHeight"     Value="32"/>
    </Style>

    <!-- ── DataGrid column header ────────────────────────────────── -->
    <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="FontFamily"    Value="Calibri"/>
        <Setter Property="FontSize"      Value="10"/>
        <Setter Property="FontWeight"    Value="Bold"/>
        <Setter Property="Foreground"    Value="White"/>
        <Setter Property="Background"    Value="#1A2E5A"/>
        <Setter Property="Padding"       Value="6,0"/>
        <Setter Property="BorderBrush"   Value="#253A6A"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <!-- ── Section header TextBlock ──────────────────────────────── -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Calibri"/>
        <Setter Property="FontSize"    Value="12"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Foreground"  Value="#460073"/>
        <Setter Property="Margin"      Value="0,0,0,4"/>
    </Style>

    <!-- ── Status icon cell styles ───────────────────────────────── -->
    <Style x:Key="StatusOkStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#065F46"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style x:Key="StatusErrorStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#7F1D1D"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- ── Login form TextBox ─────────────────────────────────────── -->
    <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
        <Setter Property="FontFamily"             Value="Calibri"/>
        <Setter Property="FontSize"               Value="12"/>
        <Setter Property="Foreground"             Value="#1E2A3B"/>
        <Setter Property="Background"             Value="White"/>
        <Setter Property="BorderBrush"            Value="#DDE1EB"/>
        <Setter Property="BorderThickness"        Value="1"/>
        <Setter Property="Padding"                Value="8,4"/>
        <Setter Property="Height"                 Value="28"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="#460073"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
