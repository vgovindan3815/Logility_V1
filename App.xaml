<Application x:Class="Application"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:Logility_Freight.Core"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <core:BoolToVisibilityConverter   x:Key="BoolToVisibilityConverter"/>
            <core:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <core:BoolToStatusColorConverter  x:Key="BoolToStatusColorConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
