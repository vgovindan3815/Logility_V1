    <Page Include="Resources\Styles.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
  </ItemGroup>

  <!-- ── VB source files ───────────────────────────────────── -->
  <ItemGroup>
    <Compile Include="App.xaml.vb">
      <DependentUpon>App.xaml</DependentUpon>
      <SubType>Code</SubType>
    </Compile>

    <!-- Core -->
    <Compile Include="Core\BaseViewModel.vb" />
    <Compile Include="Core\Converters.vb" />
    <Compile Include="Core\CsvHelper.vb" />
    <Compile Include="Core\ExcelLoader.vb" />
    <Compile Include="Core\Exceptions.vb" />
    <Compile Include="Core\RelayCommand.vb" />
    <Compile Include="Core\SessionManager.vb" />

    <!-- Models -->
    <Compile Include="Models\BatchRowBase.vb" />
    <Compile Include="Models\FXF3A_BatchRow.vb" />
    <Compile Include="Models\FXF3BtoG_BatchRows.vb" />
    <Compile Include="Models\FXF3JtoN_4M_BatchRows.vb" />

    <!-- ViewModels -->
    <Compile Include="ViewModels\MainViewModel.vb" />
    <Compile Include="ViewModels\LoginViewModel.vb" />
    <Compile Include="ViewModels\FXF3A_ViewModel.vb" />
    <Compile Include="ViewModels\FXF3BtoG_ViewModels.vb" />
    <Compile Include="ViewModels\FXF3JtoN_4M_ViewModels.vb" />

    <!-- Views code-behind -->
    <Compile Include="Views\MainWindow.xaml.vb">
      <DependentUpon>MainWindow.xaml</DependentUpon>
