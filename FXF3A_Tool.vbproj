<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props"
          Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <PlatformTarget>x64</PlatformTarget>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <StartupObject>FXF3A_Tool.Application</StartupObject>
    <RootNamespace>FXF3A_Tool</RootNamespace>
    <AssemblyName>FXF3A_Tool</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <MyType>Windows</MyType>
    <Deterministic>true</Deterministic>
    <OptionInfer>On</OptionInfer>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <DefineConstants>DEBUG=True,TRACE=True</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <DefineConstants>TRACE=True</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
  </PropertyGroup>

  <!-- ── Standard framework references ─────────────────────── -->
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Data" />
    <Reference Include="System.Xml" />
    <Reference Include="System.Xaml" />
    <Reference Include="WindowsBase" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="System.Windows.Forms" />
  </ItemGroup>

  <!-- ── FedEx screen scraping DLLs ────────────────────────── -->
  <!-- All DLLs must be copied to the deploy\ folder first.    -->
  <ItemGroup>
    <Reference Include="FedEx.PABST.SS.Exceptions">
      <HintPath>deploy\FedEx.PABST.SS.Exceptions.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.SSLib">
      <HintPath>deploy\FedEx.PABST.SS.SSLib.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.Screens.FXF3A">
      <HintPath>deploy\FedEx.PABST.SS.Screens.FXF3A.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.Screens.FXF3B">
      <HintPath>deploy\FedEx.PABST.SS.Screens.FXF3B.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.Screens.FXF3C">
      <HintPath>deploy\FedEx.PABST.SS.Screens.FXF3C.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.Screens.FXF3D">
      <HintPath>deploy\FedEx.PABST.SS.Screens.FXF3D.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.Screens.FXF3E">
      <HintPath>deploy\FedEx.PABST.SS.Screens.FXF3E.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.Screens.FXF3F">
      <HintPath>deploy\FedEx.PABST.SS.Screens.FXF3F.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.Screens.FXF3G">
      <HintPath>deploy\FedEx.PABST.SS.Screens.FXF3G.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.Screens.FXF3J">
      <HintPath>deploy\FedEx.PABST.SS.Screens.FXF3J.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.Screens.FXF3K">
      <HintPath>deploy\FedEx.PABST.SS.Screens.FXF3K.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.Screens.FXF3M">
      <HintPath>deploy\FedEx.PABST.SS.Screens.FXF3M.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.Screens.FXF3N">
      <HintPath>deploy\FedEx.PABST.SS.Screens.FXF3N.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="FedEx.PABST.SS.Screens.FXF4M">
      <HintPath>deploy\FedEx.PABST.SS.Screens.FXF4M.dll</HintPath>
      <Private>True</Private>
    </Reference>
  </ItemGroup>

  <!-- ── Copy fxf3270.rsf and Bluezone interop to output ── -->
  <ItemGroup>
    <Content Include="deploy\fxf3270.rsf">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- Interop.BZWHLLLIB.dll — COM interop wrapper for Bluezone.      -->
    <!-- Must be referenced (not Content) so it copies flat to bin\     -->
    <!-- alongside the exe. Obtain from Bluezone installation dir.      -->
  </ItemGroup>
  <ItemGroup Condition="Exists('deploy\Interop.BZWHLLLIB.dll')">
    <Reference Include="Interop.BZWHLLLIB">
      <HintPath>deploy\Interop.BZWHLLLIB.dll</HintPath>
      <Private>True</Private>
      <EmbedInteropTypes>False</EmbedInteropTypes>
    </Reference>
  </ItemGroup>

  <!-- ── Application entry point ───────────────────────────── -->
  <ItemGroup>
    <ApplicationDefinition Include="App.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </ApplicationDefinition>
  </ItemGroup>

  <!-- ── XAML views ─────────────────────────────────────────── -->
  <ItemGroup>
    <Page Include="Views\MainWindow.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
    <Page Include="Views\LoginView.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
